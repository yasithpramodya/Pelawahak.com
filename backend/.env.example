# ============================================================
# Pelawahak.lk Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database (REQUIRED) ──────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/Pelawahak?appName=Cluster0

# ── JWT (REQUIRED) ───────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_min_64_chars
JWT_EXPIRES_IN=30d

# ── Admin seed account ───────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe@123
ADMIN_NAME=Admin

# ── CORS (comma-separated for multiple origins) ──────────────
CLIENT_URL=http://localhost:5173,http://localhost:5174

# ── Cloudinary (optional — falls back to local disk storage) ─
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── PayPal (optional — payment routes return 500 if missing) ─
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com
UNLOCK_PRICE_USD=2.99

# ── Email / SMTP (optional — falls back to console log) ──────
# EMAIL_SERVICE=gmail
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=you@gmail.com
# EMAIL_PASS=your_app_password
# EMAIL_FROM="Pelawahak.com" <noreply@pelawahak.com>